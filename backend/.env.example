# Server
PORT=4000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/admin-ecommerce-mvp

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email (Brevo) — también configurable desde Admin > Configuración > Email
EMAIL_PASS=your-brevo-api-key
EMAIL_FROM=noreply@yourdomain.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Public API URL (GalioPay webhooks)
PUBLIC_API_URL=http://localhost:4000

# GalioPay — también configurable desde Admin > Configuración > Pagos
GALIO_API_KEY=your-galio-api-key
GALIO_CLIENT_ID=your-galio-client-id
GALIO_SANDBOX=true

# Pending Galio orders — GalioPay links expire after 15 minutes
PENDING_ORDER_TTL_MINUTES=15
PENDING_ORDER_SWEEP_MS=120000

# Cloudinary (Image Storage)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret